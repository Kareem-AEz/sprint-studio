# ------------ Database URL ------------
# Local SQLite (used by prisma migrate dev and local dev without Turso)
DATABASE_URL="file:./database/db.sqlite"

# ------------ Turso (LibSQL) ------------
# Set these to use Turso in production (Vercel) or locally against Turso
# Leave unset to fall back to local SQLite
TURSO_DATABASE_URL="libsql://your-db-name.turso.io"
TURSO_AUTH_TOKEN="your-turso-auth-token"

# ------------ Central License Key ------------
# MUST BE SET TO INSTALL CENTRAL ICONS
# export CENTRAL_LICENSE_KEY=review

# Needs env for vercel to build
CENTRAL_LICENSE_KEY=review


# ┌─────────────────────────────────────────────────────────────────────────────
# │ convit — dev only. Do not commit. These vars are for local development
# │ and should not be uploaded or shared with other env vars.
# └─────────────────────────────────────────────────────────────────────────────
# Base URL — used for all LLM requests
CONVIT_URL="https://api.openai.com/v1"

# API key — required for cloud. Omit for local
CONVIT_KEY="sk-..."

# Model ID — omit to auto-detect from LM Studio
CONVIT_MODEL="gpt-4o-mini"

# Cost per 1M input tokens (USD)
# CONVIT_INPUT_COST="0.15"

# Cost per 1M output tokens (USD)
# CONVIT_OUTPUT_COST="0.60"

# Request timeout (ms)
# CONVIT_TIMEOUT="60000"